{
  "collections": [
    {
      "name": "users",
      "type": "auth",
      "fields": [
        { "name": "name", "type": "text", "required": true },
        { "name": "role", "type": "select", "required": true, "values": ["user", "admin", "agency"] },
        { "name": "aiCredits", "type": "number", "required": true },
        { "name": "suspended", "type": "bool" },
        { "name": "emailVerified", "type": "bool" }
      ],
      "indexes": ["CREATE INDEX idx_users_role ON users (role)"]
    },
    {
      "name": "plans",
      "type": "base",
      "fields": [
        { "name": "slug", "type": "text", "required": true },
        { "name": "price", "type": "number", "required": true },
        { "name": "aiCreditLimit", "type": "number", "required": true },
        { "name": "instagramAccountLimit", "type": "number", "required": true }
      ]
    },
    {
      "name": "subscriptions",
      "type": "base",
      "fields": [
        { "name": "user", "type": "relation", "collection": "users", "required": true },
        { "name": "plan", "type": "relation", "collection": "plans", "required": true },
        { "name": "status", "type": "select", "values": ["active", "trial", "cancelled", "past_due"] },
        { "name": "provider", "type": "text" },
        { "name": "providerSubscriptionId", "type": "text" },
        { "name": "currentPeriodEnd", "type": "date" }
      ],
      "indexes": ["CREATE INDEX idx_subscriptions_user_status ON subscriptions (user, status)"]
    },
    {
      "name": "instagram_accounts",
      "type": "base",
      "fields": [
        { "name": "user", "type": "relation", "collection": "users", "required": true },
        { "name": "instagramId", "type": "text", "required": true },
        { "name": "username", "type": "text", "required": true },
        { "name": "encryptedAccessToken", "type": "text", "required": true },
        { "name": "tokenExpiresAt", "type": "date" }
      ],
      "indexes": ["CREATE UNIQUE INDEX idx_instagram_unique_account ON instagram_accounts (instagramId)"]
    },
    {
      "name": "posts",
      "type": "base",
      "fields": [
        { "name": "account", "type": "relation", "collection": "instagram_accounts", "required": true },
        { "name": "postId", "type": "text", "required": true },
        { "name": "caption", "type": "text" },
        { "name": "likes", "type": "number" },
        { "name": "comments", "type": "number" },
        { "name": "reach", "type": "number" }
      ]
    },
    {
      "name": "reels",
      "type": "base",
      "fields": [
        { "name": "account", "type": "relation", "collection": "instagram_accounts", "required": true },
        { "name": "reelId", "type": "text", "required": true },
        { "name": "title", "type": "text" },
        { "name": "views", "type": "number" },
        { "name": "likes", "type": "number" },
        { "name": "comments", "type": "number" },
        { "name": "shares", "type": "number" }
      ],
      "indexes": ["CREATE INDEX idx_reels_account_views ON reels (account, views)"]
    },
    {
      "name": "analytics",
      "type": "base",
      "fields": [
        { "name": "account", "type": "relation", "collection": "instagram_accounts", "required": true },
        { "name": "date", "type": "date", "required": true },
        { "name": "engagementRate", "type": "number" },
        { "name": "followers", "type": "number" },
        { "name": "followerGrowth", "type": "number" }
      ],
      "indexes": ["CREATE INDEX idx_analytics_account_date ON analytics (account, date)"]
    },
    {
      "name": "ai_usage",
      "type": "base",
      "fields": [
        { "name": "user", "type": "relation", "collection": "users", "required": true },
        { "name": "promptType", "type": "text", "required": true },
        { "name": "creditsUsed", "type": "number", "required": true }
      ]
    },
    {
      "name": "webhook_logs",
      "type": "base",
      "fields": [
        { "name": "provider", "type": "text" },
        { "name": "payload", "type": "json" },
        { "name": "status", "type": "text" }
      ]
    },
    {
      "name": "admin_settings",
      "type": "base",
      "fields": [
        { "name": "key", "type": "text", "required": true },
        { "name": "value", "type": "json" }
      ]
    }
  ]
}
